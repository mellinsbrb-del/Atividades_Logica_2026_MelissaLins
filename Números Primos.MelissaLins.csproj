onsole.OutputEncoding = System.Text.Encoding.UTF8;
Console.WriteLine("\nListagem de números pares");
Console.Write("Digite o número limite: ");

int.TryParse(Console.ReadLine()!, out int num);

Console.WriteLine($"\nNúmeros pares entre 1 e {num}:");

for (int i = 1; i <= num; i++)
{
    if (i % 2 == 0)
    {
        Console.Write(i + " ");
    }
}

Console.WriteLine("\n\nFim da execução.");
