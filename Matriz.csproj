Console.WriteLine("🤖 Iniciando Cálculo de Matrizes...");

int[,] vetA = { { 1, 2, 3 }, { 4, 5, 6 }, { 7, 8, 9 } };
int[,] vetB = { { 9, 8, 7 }, { 6, 5, 4 }, { 3, 2, 1 } };


int[,] matrizC = new int[3, 3];

for (int i = 0; i < 3; i++) 
{
    for (int j = 0; j < 3; j++) 
    {
        for (int k = 0; k < 3; k++) 
        {
            matrizC[i, j] += vetA[i, k] * vetB[k, j];
        }
    }
}

Console.WriteLine("\n📊 Resultado:");
for (int i = 0; i < 3; i++)
{
    for (int j = 0; j < 3; j++)
    {
        Console.Write(matrizC[i, j] + "\t");
    }
    Console.WriteLine();
}
